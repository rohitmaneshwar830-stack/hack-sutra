# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://localhost:27017/ganga_guardian

# JWT secret key (change this to a strong random string in production)
JWT_SECRET=replace-with-at-least-32-random-characters

# Cloudinary credentials (free tier - https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Python ML service URL
ML_SERVICE_URL=http://localhost:5001

# Browser/API configuration
FRONTEND_URL=http://localhost:5173
API_RATE_LIMIT=200

# Official provider URLs. Leave unset until a supported official feed is available.
CPCB_DATA_URL=
INDIA_WRIS_DATA_URL=

# Optional configured satellite tile provider
SATELLITE_TILE_URL=
SATELLITE_ATTRIBUTION=

# Used only by `npm run provision-admin`; never commit these values.
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Server port
PORT=5000
